/dts-v1/;
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pinctrl/mt65xx.h>

#include "mt7986a.dtsi"

/ {
        compatible = "tplink,er7412-m2", "mediatek,mt7986a";
        model = "TP-Link ER7412-M2";

	aliases {
		serial0 = &uart0;
	};

        chosen {
		stdout-path = "serial0:115200n8";
        };

        memory@40000000 {
                reg = <0 0x40000000 0 0x40000000>;
		device_type = "memory";
        };
/*
	gpio-keys {
		compatible = "gpio-keys";

		button-reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&pio 0 GPIO_ACTIVE_LOW>;
		};
	};

	gpio-leds {
		compatible = "gpio-leds";

		led-power {
		};

		led-sys {
		};

		led-usb {
		};
	};
*/
};

&crypto {
	status = "okay";
};

&eth {
	status = "okay";
};

&pio {
	spi_flash_pins: spi-flash-pins-33-to-38 {
		mux {
			function = "flash";
			groups = "spi0", "spi0_wp_hold";
		};
		conf-pu {
			pins = "SPI2_CS", "SPI2_HOLD", "SPI2_WP";
			drive-strength = <MTK_DRIVE_8mA>;
			bias-pull-up = <MTK_PUPD_SET_R1R0_11>;
		};
		conf-pd {
			pins = "SPI2_CLK", "SPI2_MOSI", "SPI2_MISO";
			drive-strength = <MTK_DRIVE_8mA>;
			bias-pull-down = <MTK_PUPD_SET_R1R0_11>;
		};
	};
};

&spi0 {
	pinctrl-names = "default";
        pinctrl-0 = <&spi_flash_pins>;
        status = "okay";

	flash@0 {
		compatible = "spi-nand";
		reg = <1>;

		spi-max-frequency = <52000000>;
		spi-tx-buswidth = <4>;
		spi-rx-buswidth = <4>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "BL2";
				reg = <0x00000 0x0100000>;
				read-only;
			};

			partition@100000 {
				compatible = "u-boot,env";
				label = "u-boot-env";
				reg = <0x0100000 0x0080000>;
			};

			partition@180000 {
				label = "Factory";
				reg = <0x180000 0x0200000>;
				read-only;
			};

			partition@380000 {
				label = "FIP";
				reg = <0x380000 0x0200000>;
				read-only;
			};

			partition@580000 {
				label = "ubi";
				reg = <0x580000 0x2300000>;
			};

			partition@2880000 {
				label = "ubi.b";
				reg = <0x2880000 0x2300000>;
				read-only;
			};

			partition@4b80000 {
				label = "database";
				reg = <0x4b80000 0x1e00000>;
				read-only;
			};

			partition@6980000 {
				label = "support-list";
				reg = <0x6980000 0x0020000>;
				read-only;
			};

			partition@69a0000 {
				label = "user-config";
				reg = <0x69a0000 0x0a00000>;
				read-only;
			};

			partition@73a0000 {
				label = "partition-table";
				reg = <0x73a0000 0x0020000>;
				read-only;
			};

			partition@73c0000 {
				label = "device-info";
				reg = <0x73c0000 0x0020000>;
				read-only;
			};

			partition@73e0000 {
				label = "device-info.b";
				reg = <0x73e0000 0x0020000>;
				read-only;
			};

			partition@7400000 {
				label = "tddp";
				reg = <0x7400000 0x0020000>;
				read-only;
			};

			partition@7420000 {
				label = "tddp.b";
				reg = <0x7420000 0x0020000>;
				read-only;
			};

			partition@7440000 {
				label = "extra-para-ubi";
				reg = <0x7440000 0x0200000>;
				read-only;
			};

			partition@7640000 {
				label = "firmware-info";
				reg = <0x7640000 0x0020000>;
				read-only;
			};

			partition@7660000 {
				label = "firmware-info.b";
				reg = <0x7660000 0x0020000>;
				read-only;
			};

			partition@7680000 {
				label = "log";
				reg = <0x7680000 0x0200000>;
				read-only;
			};

			partition@7880000 {
				label = "log.b";
				reg = <0x7880000 0x0200000>;
				read-only;
			};

			partition@7A80000 {
				label = "log_recovery";
				reg = <0x7A80000 0x0080000>;
				read-only;
			};

			partition@7B00000 {
				label = "panic-oops";
				reg = <0x7B00000 0x0080000>;
				read-only;
			};
		};
	};
};

&trng {
	status = "okay";
};

&uart0 {
	status = "okay";
};

&usb_phy {
	status = "okay";
};

&watchdog {
	status = "okay";
};
