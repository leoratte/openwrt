/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include "ipq5332.dtsi"

/ {
	model = "AVM Fritz!Box 7690";
	compatible = "avm,fritzbox7690", "qcom,ipq5332";

	aliases {
		serial0 = &blsp1_uart0;
	};

	keys {
		compatible = "gpio-keys";

		wlan {
			label = "wlan";
			gpios = <&tlmm 0x32 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RFKILL>;
		};

		wps {
			label = "wps";
			gpios = <&tlmm 0x17 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};

		dect {
			label = "dect";
			gpios = <&tlmm 0x22 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_PHONE>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_power: led_power {
			function = LED_FUNCTION_POWER;
			gpios = <&tlmm 4 GPIO_ACTIVE_HIGH>;
		};

		led_wlan: led_wlan {
			function = LED_FUNCTION_WLAN;
			gpios = <&tlmm 3 GPIO_ACTIVE_HIGH>;
		};

		led_fon_dect: led_fon_dect {
			gpios = <&tlmm 6 GPIO_ACTIVE_HIGH>;
		};

		led_connect: led_connect {
			gpios = <&tlmm 0 GPIO_ACTIVE_HIGH>;
		};

		led_info_normal: led_info_normal {
			function = LED_FUNCTION_STATUS;
			gpios = <&tlmm 7 GPIO_ACTIVE_HIGH>;
		};

		led_info_error: led_info_error {
			function = LED_FUNCTION_FAULT;
			gpios = <&tlmm 2 GPIO_ACTIVE_HIGH>;
		};
	};
};

&blsp1_uart0 {
	pinctrl-0 = <&serial_0_pins>;
	pinctrl-names = "default";
	status = "okay";
};

&sdhc {
	bus-width = <4>;
	max-frequency = <192000000>;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	non-removable;
	pinctrl-0 = <&sdc_default_state>;
	pinctrl-names = "default";
	status = "okay";
};

&usb {
	status = "okay";
};

&usb_dwc {
	dr_mode = "host";
};

&tlmm {
	sdc_default_state: sdc-default-state {
		clk-pins {
			pins = "gpio13";
			function = "sdc_clk";
			drive-strength = <8>;
			bias-disable;
		};

		cmd-pins {
			pins = "gpio12";
			function = "sdc_cmd";
			drive-strength = <8>;
			bias-pull-up;
		};

		data-pins {
			pins = "gpio8", "gpio9", "gpio10", "gpio11";
			function = "sdc_data";
			drive-strength = <8>;
			bias-pull-up;
		};
	};
};
